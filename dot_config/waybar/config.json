{
  "layer": "top",
  "position": "bottom",
  "modules-left": [
    "wlr/workspaces",
    "hyprland/window"
  ],
  "modules-center": [],
  "modules-right": [
    "wireplumber",
    "battery",
    "clock"
  ],
  "height": 48,
  "hyprland/window": {
    "format": "{}",
    "separate-outputs": true
  },
  "battery": {
    "format": "{icon}",
    "format-icons": [
      "ΎΚΕ",
      "ΎΚΔ",
      "ΎΚΓ",
      "ΎΚΒ",
      "ΎΚΑ"
    ]
  },
  "wireplumber": {
    "format": "{volume}% {icon}",
    "format-muted": "ΎΑο",
    "on-click": "helvum",
    "format-icons": [
      "ΎΑο",
      "ΎΑπ",
      "ΎΑρ"
    ]
  },
  "clock": {
    "format": "{:%a, %d. %b  %H:%M}"
  }
}
