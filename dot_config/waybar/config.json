{
    "layer": "top",
    "position": "bottom",
    "modules-left": ["wlr/workspaces", "hyprland/window"],
    "modules-center": [],
    "modules-right": ["battery", "clock"],
    "height": 48,
    "hyprland/window": {
        "format": "{}",
        "separate-outputs": true
    },
    "battery": {
        "format": "{icon}",
        "format-icons": ["", "", "", "", ""]
    },
    "clock": {
        "format": "{:%a, %d. %b  %H:%M}"
    }
}