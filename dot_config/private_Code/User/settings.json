{
  "window.zoomLevel": 2,
  "workbench.colorTheme": "GitHub Dark",
  "editor.fontFamily": "'IosevkaTerm Nerd Font'",
  "editor.fontSize": 18,
  "terminal.external.linuxExec": "kitty",
  "editor.smoothScrolling": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "workbench.list.smoothScrolling": true,
  "editor.minimap.enabled": false,
  "markdown-preview-enhanced.previewTheme": "atom-light.css",
  "vim.useSystemClipboard": true,
  "explorer.confirmDelete": false,
  "[python]": {
    "editor.formatOnType": true,
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "redhat.telemetry.enabled": false,
  "editor.stickyScroll.enabled": false,
  "workbench.colorCustomizations": {
    "[Rosé Pine]": {
      "editor.background": "#11111b",
      "sideBar.background": "#11111b",
      "activityBar.background": "#11111b",
      "editorGutter.background": "#11111b",
      "breadcrumb.background": "#11111b",
      "editorStickyScroll.background": "#181825",
      "terminal.background": "#11111b",
      "panel.background": "#11111b"
    }
  },
  "window.menuBarVisibility": "toggle",
  "glassit.alpha": 255,
  "files.associations": {
    "*.tftpl": "terraform"
  },
  "svelte.enable-ts-plugin": true,
  "editor.guides.bracketPairs": "active",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "[svelte]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "explorer.confirmDragAndDrop": false,
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
